# =============================================================================
# sysPass - Docker Compose Environment Variables
# =============================================================================
# Copy this file to .env and adjust values before running:
#   cp .env.example .env
#   docker compose up -d --build
# =============================================================================

# ---------------------------------------------------------------------------
# Database (MariaDB)
# ---------------------------------------------------------------------------
MYSQL_ROOT_PASSWORD=change_me_root_password
SYSPASS_DB_PASS=change_me_app_password

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
SYSPASS_SITE_URL=http://localhost:8080
TZ=America/Sao_Paulo
